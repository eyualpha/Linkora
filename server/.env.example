PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/linkora?retryWrites=true&w=majority
# Optional: if local dev fails with "querySrv ECONNREFUSED", paste Atlas "Standard connection string" here
# MONGO_URI_STANDARD=mongodb://<username>:<password>@cluster0-shard-00-00.xxxxx.mongodb.net:27017,.../linkora?ssl=true&replicaSet=...
JWT_SECRET=

# Frontend URL(s) allowed by CORS (comma-separated for multiple)
CLIENT_URL=
CLIENT_URLS=

# --- Recommended: Resend (reliable delivery to Gmail, etc.) ---
# Sign up at https://resend.com → API Keys → create key
RESEND_API_KEY=re_xxxxxxxxxxxx
# Free testing sender (works without domain verification):
RESEND_FROM=Linkora <onboarding@resend.dev>

# --- Alternative: SMTP (Gmail / Google Workspace) ---
# Note: University Workspace (@your-school.edu) often does NOT deliver to external Gmail.
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM=your-email@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true

# Development only: log OTP to server console (never sent to clients)
DEV_LOG_OTP=false

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
